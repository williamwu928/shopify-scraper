# Shopify Scraper Environment Variables
# Copy this file to .env and fill in your values

# ──────────────────────────────────────────────────────────
# SCRAPER SETTINGS (optional — defaults work out of the box)
# ──────────────────────────────────────────────────────────
# MIN_DELAY=0.7
# MAX_DELAY=1.6
# MAX_PAGES=200

# ──────────────────────────────────────────────────────────
# OUTPUT
# ──────────────────────────────────────────────────────────
# Output directory for scraped CSV files
# OUTPUT_DIR=data

# ──────────────────────────────────────────────────────────
# GITHUB (for GitHub Actions auto-commit workflow)
# ──────────────────────────────────────────────────────────
# GITHUB_TOKEN=
# Your GitHub Personal Access Token with 'repo' scope
# Required only if using the auto-commit workflow
# Generate at: https://github.com/settings/tokens

# ──────────────────────────────────────────────────────────
# NOTIFICATIONS (optional)
# ──────────────────────────────────────────────────────────
# Discord webhook URL for notifications on scrape completion/failure
# DISCORD_WEBHOOK_URL=
