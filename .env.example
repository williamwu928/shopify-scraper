# Shopify Scraper Environment Variables
# Copy this file to .env and fill in your values

# ──────────────────────────────────────────────────────────
# REQUIRED VARIABLES
# ──────────────────────────────────────────────────────────

# ── Database ───────────────────────────────────────────────
# Neon PostgreSQL connection string (required for API backend)
# Get this from your Neon dashboard: https://neon.tech
# DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# ── API Security ───────────────────────────────────────────
# Secret API key for authenticating write operations (POST/DELETE to /api/scrape-runs)
# Generate a secure random key: python -c "import secrets; print(secrets.token_hex(32))"
# API_KEY=your-secret-api-key-here

# ──────────────────────────────────────────────────────────
# OPTIONAL VARIABLES
# ──────────────────────────────────────────────────────────

# ── Scraper Settings ───────────────────────────────────────
# MIN_DELAY=0.7
# MAX_DELAY=1.6
# MAX_PAGES=200

# ── Output ────────────────────────────────────────────────
# Output directory for scraped CSV files
# OUTPUT_DIR=data

# ── GitHub (for GitHub Actions auto-commit workflow) ────────
# GITHUB_TOKEN=
# Your GitHub Personal Access Token with 'repo' scope
# Required only if using the auto-commit workflow
# Generate at: https://github.com/settings/tokens

# ── Backend URL (auto-injected by Railway, used for CORS) ─
# RAILWAY_PUBLIC_URL=https://your-app.up.railway.app

# ── Notifications ──────────────────────────────────────────
# Discord webhook URL for notifications on scrape completion/failure
# DISCORD_WEBHOOK_URL=
