# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
*.egg-info/
dist/
build/

# Virtual environments
venv/
env/
.venv/

# IDE
.vscode/
.idea/

# Environment variables
.env
.env.local
.env.production

# Logs
*.log

# Scraped CSV backups (timestamped archives — never commit these)
data/backups/*
# …except keep the directory itself tracked
!data/backups/.gitkeep

# OS files
.DS_Store
Thumbs.db

# Debug files
debug.html
debug.png

# Backend helper scripts (development only, not for deployment)
backend/debug_db.py
backend/cleanup_and_seed.py
backend/test_api.py
backend/reimport_csv.py
backend/migrate_csv_sha.py
