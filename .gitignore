# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
*.egg-info/
dist/
build/

# Virtual environments
venv/
env/
.venv/

# IDE
.vscode/
.idea/

# Environment variables
.env
.env.local

# Logs
*.log

# Scraped CSV backups (timestamped archives — never commit these)
data/backups/*
# …except keep the directory itself tracked
!data/backups/.gitkeep

# OS files
.DS_Store
Thumbs.db
